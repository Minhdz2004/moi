<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="UTF-8">
	<meta name="theme-color" content="#2a7ee4">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="author" content="IE104.O12_Nhom2">
	<meta name="description" content="Chào mừng bạn đến với Mayor Wolf - địa chỉ mua sắm trực tuyến hàng đầu về điện máy! Khám phá thế giới công nghệ với sự đa dạng và chất lượng tốt nhất từ máy tính, điện thoại di động đến các sản phẩm gia dụng thông minh. Mua sắm an toàn, thuận tiện và tiết kiệm ngay hôm nay với các ưu đãi độc quyền. Mayor Wolf - Nơi nâng cao cuộc sống thông qua công nghệ!.">
	<link rel="shortcut icon" type="image/x-icon" href="/imgs/ico-logo-blue.png">
	<link rel="stylesheet" href="/styles/admin/pages/cate_view_admin.css">

	<title>Mayor Wolf.Admin - Thêm danh mục</title>
</head>

<body>
	<div class="grid-container">

		<%- include('../partials/sidebar_admin') %>
		<%- include('../partials/header_admin', {title: title}) %>

		<main class="main-container">

			<div class="page-header">
				<div class="row align-items-center">

					<% var pageAction = (typeof category !== 'undefined' && category) ? 'Chỉnh sửa' : 'Thêm' %>
					<%- include('../partials/breadcrumb.ejs', breadcrumb=[{text: 'Danh mục sản phẩm', link: '/admin/categories_admin' }, {text: pageAction , link: '#' }]) %>

						<div class="page-header__title">
							<h1><%= pageAction %> danh mục sản phẩm</h1>
						<button type="submit" class="btn-admin btn-primary" id="saveCategoryBtn" form="categoryForm">
							<span class="material-symbols-outlined"> save </span> Lưu
						</button>
					</div>
				</div>
			</div>

			<div class="row">
				<div class="main-form">
					<form id="categoryForm" method="POST" action="/admin/categories_admin/add">
						<div class="card">
							<div class="card-header">
								<h4 class="card-header-title">Thông tin danh mục sản phẩm</h4>
							</div>

							<div class="card-body">
								<div>
									<label for="category-name-label" class="form-label">Tên danh mục sản phẩm</label>
									<input type="text" class="form-control" name="categoryName" id="category-name-label" placeholder="Nhập tên danh mục sản phẩm" value="<%= (typeof category !== 'undefined' && category) ? category.category_name : '' %>">
								</div>
								<div>
									<label for="category-desc-label" class="form-label">Mô tả danh mục</label>
									<textarea class="form-control" name="categoryDesc" id="category-desc-label" placeholder="Nhập mô tả danh mục" rows="4"><%= (typeof category !== 'undefined' && category) ? category.category_desc : '' %></textarea>
								</div>
							</div>
						</div>

						<div class="card">
							<div class="card-header">
								<h4>Ảnh</h4>
							</div>

							<div class="card-body">
								<div class="dz-dropzone dz-dropzone-card">
									<div class="dz-message">
										<img class="img-upload" src="/imgs/admin/img-upload.svg" alt="Image Description" data-hs-theme-appearance="default">
										<h5>Kéo và thả hình ảnh tại đây</h5>
										<p>hoặc</p>
										<div class="dz-message-btn">
												<input type="file" name="image" id="imageUpload" accept="image/*" style="display: none">
												<label for="imageUpload" class="image-upload-label">
													<span class="material-symbols-rounded"> upload </span> 
													Thêm hình ảnh
												</label>
										</div>
									</div>
								</div>
							</div>
						</div>
					</form>
				</div>
			</div>
		</main>

	</div>

	<script src="/scripts/admin/cate_view_admin.js"></script>
	<script src="/scripts/admin/index_admin.js"></script>

	<!-- hidden category metadata for client script -->
	<div id="category-data" style="display:none" data-category-id="<%= (typeof category !== 'undefined' && category) ? category.category_id : '' %>"></div>

	<script>
		const categoryForm = document.getElementById('categoryForm');
		const saveCategoryBtn = document.getElementById('saveCategoryBtn');

		if (saveCategoryBtn && categoryForm) {
			saveCategoryBtn.addEventListener('click', function(e) {
				e.preventDefault();
				console.log('Save button clicked');
				
				// Collect form data
				const categoryName = document.querySelector('[name="categoryName"]').value;
				const categoryDesc = document.querySelector('[name="categoryDesc"]').value;
					const imageInput = document.getElementById('imageUpload');
					const categoryDataEl = document.getElementById('category-data');
					const editCategoryId = categoryDataEl && categoryDataEl.dataset && categoryDataEl.dataset.categoryId ? categoryDataEl.dataset.categoryId : null;
				
				console.log('categoryName:', categoryName);
				console.log('categoryDesc:', categoryDesc);

				if (!categoryName.trim()) {
					alert('Tên danh mục không được để trống');
					return;
				}

					const sendRequest = (data, url) => {
					console.log('Sending data:', data);

						fetch(url, {
						method: 'POST',
						credentials: 'same-origin',
						headers: {
							'Content-Type': 'application/json'
						},
						body: JSON.stringify(data)
						})
					.then(response => {
						console.log('Response:', response);
						if (!response.ok) {
							throw new Error('HTTP error, status = ' + response.status);
						}
						return response.json();
					})
					.then(result => {
						console.log('Result:', result);
						if (result.success) {
							alert(result.message);
							window.location.href = result.redirect;
						} else {
							alert('Lỗi: ' + result.message);
						}
					})
					.catch(error => {
						console.error('Error:', error);
						alert('Có lỗi xảy ra: ' + error.message);
					});
				}

				// If image selected, read it as base64 then send
				// build endpoint URL depending on add vs edit
				const endpoint = editCategoryId ? `/admin/categories_admin/edit/${editCategoryId}` : '/admin/categories_admin/add';

				if (imageInput && imageInput.files && imageInput.files.length > 0) {
					const file = imageInput.files[0];
					const reader = new FileReader();
					reader.onload = function(evt) {
						const imageData = evt.target.result; // data URL
						const data = {
							categoryName: categoryName,
							categoryDesc: categoryDesc,
							imageName: file.name,
							imageData: imageData
						};
						sendRequest(data, endpoint);
					};
					reader.onerror = function(err) {
						console.error('File read error:', err);
						alert('Không thể đọc file ảnh');
					};
					reader.readAsDataURL(file);
				} else {
					const data = {
						categoryName: categoryName,
						categoryDesc: categoryDesc
					};
					sendRequest(data, endpoint);
				}
			});
		}
	</script>

</body>

</html>